LLM_API_KEY=your-chat-api-key
LLM_BASE_URL=https://example.com/v1
LLM_MODEL=your-chat-model

EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://example.com/v1
EMBEDDING_MODEL=your-embedding-model

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=enterprise-crag
LANGSMITH_HIDE_INPUTS=false
LANGSMITH_HIDE_OUTPUTS=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_rag_chunks_hybrid
EMBEDDING_DIMENSION=1024
RELEVANCE_MAX_CONCURRENCY=4
# Deprecated: normal relevance admission is handled by the external reranker.
RELEVANCE_GRADING_ENABLED=false
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_TYPES=normalize,direct,multi_query
# Optional for specialist corpora: add hyde and/or step_back.
QUERY_REWRITE_MAX_QUERIES=3
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_QUERIES=1
WEB_SEARCH_RESULT_COUNT=5
WEB_SEARCH_TIMEOUT_SECONDS=10
WEB_SEARCH_MAX_RETRIES=2
TAVILY_API_KEY=
TAVILY_ENDPOINT=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=basic
TAVILY_TOPIC=general
RERANKER_TYPE=external
# RERANKER_TYPE can be default, identity, or external. Production requires external.
RERANKER_ENDPOINT=
RERANKER_API_KEY=
RERANKER_MODEL=
RERANKER_MIN_SCORE=0.5
RERANKER_TOP_K=6
# reject, vector, or llm. vector requires RETRIEVAL_MIN_SCORE.
RERANKER_FAILURE_STRATEGY=reject
RETRIEVAL_MODE=hybrid
RETRIEVAL_CANDIDATE_COUNT=10
RETRIEVAL_DENSE_LIMIT=10
RETRIEVAL_SPARSE_LIMIT=10
RETRIEVAL_RRF_K=60
# Leave empty to disable score filtering.
RETRIEVAL_MIN_SCORE=
RETRIEVAL_MAX_CHUNKS_PER_DOCUMENT=3
FINAL_CONTEXT_COUNT=6
RAG_CITATION_RETRY_COUNT=1
RAG_MIN_RELEVANT_DOCUMENTS=1

SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=mysql+pymysql://rag:rag_password@localhost:3307/rag?charset=utf8mb4
REDIS_URL=redis://localhost:6380/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=rag_minio
MINIO_SECRET_KEY=rag_minio_password
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_DEPARTMENT_NAME=Default Department

STREAMLIT_API_URL=http://localhost:8000
